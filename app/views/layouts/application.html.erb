<!DOCTYPE html>
<html>
  <head>
    <title>Crud</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav style="
      background: #1a1a2e;
      padding: 12px 24px;
      display: flex;
      gap: 8px;
      align-items: center;
    ">
      <%= link_to "Users", users_path, 
            style: "
              color: white; 
              text-decoration: none; 
              padding: 8px 20px; 
              border-radius: 4px;
              background: #{request.path.start_with?('/users') ? '#4CAF50' : 'transparent'};
            " %>

      <%= link_to "Chat", chat_path, 
            style: "
              color: white; 
              text-decoration: none; 
              padding: 8px 20px; 
              border-radius: 4px;
              background: #{request.path == '/chat' ? '#4CAF50' : 'transparent'};
            " %>
    </nav>

    <% flash.each do |type, message| %>
      <div style="
        padding: 12px 24px;
        color: <%= type == 'notice' ? '#155724' : '#721c24' %>;
        border-bottom: 1px solid <%= type == 'notice' ? '#c3e6cb' : '#f5c6cb' %>;
      ">
        <%= message %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
<div style="max-width: 600px; margin: 50px auto;">
  <h2>Live Chat</h2>

  <div id="messages" style="
    border: 1px solid #ccc;
    height: 400px;
    overflow-y: auto;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 4px;
  ">
    <% Message.with_attached_images.order(created_at: :asc).last(50).each do |message| %>
      <div class="message" style="margin-bottom: 8px;">
        <span style="color: #888; font-size: 12px;">
          <%= message.created_at.in_time_zone.strftime("%H:%M") %>
        </span>

        <% if message.content.present? %>
          <div><%= message.content %></div>
        <% end %>

        <% if message.images.attached? %>
          <% message.images.each do |image| %>
            <%= image_tag url_for(image), style: "max-width: 200px; display: block; margin-top: 4px; border-radius: 4px;" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Trix rich text editor %>
  <div style="margin-bottom: 8px;">
    <%= tag.div data: { controller: "chat-form" } do %>
      <trix-editor id="message_content" 
                   style="min-height: 100px; border: 1px solid #ccc; border-radius: 4px; padding: 8px;">
      </trix-editor>
      <input type="hidden" id="message_content_input" name="content">

      <div style="display: flex; gap: 8px; margin-top: 8px;">
        <button id="send_rich_button"
          style="padding: 8px 16px; background: #4CAF50; color: white; border: none; border-radius: 4px; cursor: pointer;">
          Send
        </button>

        <input type="file" id="image_input" accept="image/*" multiple style="flex: 1;" />
        <button id="send_image_button"
          style="padding: 8px 16px; background: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer;">
          Send Image
        </button>
      </div>
    <% end %>
  </div>
</div>